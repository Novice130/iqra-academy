// ============================================================================
// QURAN LEARNING MANAGEMENT SYSTEM — PRISMA SCHEMA
// ============================================================================
//
// 📚 EDUCATIONAL NOTE FOR JUNIOR DEVS:
// This file defines the entire database structure using Prisma's schema language.
// Prisma reads this file and generates:
//   1. TypeScript types for every table (type-safe database queries)
//   2. SQL migrations to create/update your database tables
//
// KEY DESIGN DECISIONS:
// - Every tenant-scoped table has `orgId` — this is the multi-tenant pattern.
//   It means one database can serve multiple organizations safely.
// - We use a "ledger pattern" for quotas — instead of a simple counter,
//   we track each booking event so we can audit exactly why a student
//   has N remaining classes this week.
// - Soft deletes (deletedAt) on critical tables so data is never truly lost.
// - All IDs use `cuid()` — URL-safe, collision-resistant, sortable by time.
//
// NAMING CONVENTIONS:
// - Models: PascalCase (e.g., StudentProfile)
// - Fields: camelCase (e.g., createdAt)
// - Enums: SCREAMING_SNAKE_CASE (e.g., USER_ROLE)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NOTE (Prisma 7.x): url and directUrl are now in prisma.config.ts
}

// ============================================================================
// ENUMS
// ============================================================================

/// The four roles in the system, ordered by increasing privilege.
/// 📚 WHY ENUMS? Enums are enforced at the database level — if someone tries
/// to insert "HACKER" as a role, the database will reject it. This is
/// defense-in-depth: even if our application code has a bug, the DB protects us.
enum UserRole {
  STUDENT
  TEACHER
  ORG_ADMIN
  SUPER_ADMIN
}

/// The type of live session. Each type has different rules:
/// - INDIVIDUAL: 1 teacher + 1 student, 30 min, full chat
/// - GROUP: 1 teacher + up to 3 students, 30 min, full chat
/// - WEBINAR: 1 teacher + up to 20 students, muted, Q&A last 5 min only
enum SessionType {
  INDIVIDUAL
  GROUP
  WEBINAR
}

/// Tracks the lifecycle of a session from scheduled → completed/cancelled.
/// 📚 WHY A STATE MACHINE? Sessions go through predictable states.
/// Making these explicit prevents impossible states like "a cancelled session
/// that is also in progress." Our application code checks the current status
/// before allowing transitions (e.g., only IN_PROGRESS → COMPLETED).
enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

/// Subscription status mirrors Stripe's subscription statuses.
/// We store this locally so we can query it without calling Stripe every time.
enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  UNPAID
  PAUSED
}

/// How the student pays. Manual invoice is the default (US-only).
/// 📚 WHY MANUAL INVOICE DEFAULT? In Islamic education, many families prefer
/// to receive an invoice and pay on their own schedule. Stripe's
/// `collection_method: 'send_invoice'` sends a hosted invoice link via email.
enum PaymentMethod {
  MANUAL_INVOICE
  AUTO_CHARGE
}

/// The plan tier determines pricing and session type access.
enum PlanTier {
  FREE
  INDIVIDUAL
  GROUP
  SIBLINGS
}

/// Booking status tracks whether a scheduled class was attended.
enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

/// Audit log action categories for security compliance.
enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  ROLE_CHANGED
  IMPERSONATION_START
  IMPERSONATION_END
  PAYMENT_RECEIVED
  REFUND_ISSUED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_CANCELLED
  SESSION_CREATED
  SESSION_COMPLETED
  BOOKING_CREATED
  BOOKING_CANCELLED
  CHAT_MESSAGE_HIDDEN
  COUPON_CREATED
  EXPORT_GENERATED
  SETTINGS_CHANGED
}

// ============================================================================
// MODELS
// ============================================================================

/// Organization represents a tenant in our multi-tenant system.
/// 📚 MULTI-TENANT ARCHITECTURE: Every organization gets its own isolated
/// data space. A Quran school in Texas and one in New York can both use
/// this system without seeing each other's data. The `orgId` foreign key
/// on almost every other table enforces this boundary.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique /// URL-friendly identifier (e.g., "al-noor-academy")
  domain    String?  /// Optional custom domain
  logoUrl   String?
  timezone  String   @default("America/New_York") /// US-only, but supports all US timezones
  settings  Json     @default("{}") /// Flexible JSON for org-specific settings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? /// Soft delete — never truly delete an org

  // Relations
  users         User[]
  plans         Plan[]
  subscriptions Subscription[]
  sessions      Session[]
  bookings      Booking[]
  chatMessages  ChatMessage[]
  coupons       Coupon[]
  auditLogs     AuditLog[]

  @@map("organizations")
}

/// User is the core identity model. A user belongs to exactly one org.
/// 📚 WHY SEPARATE USER AND STUDENT PROFILE?
/// A parent (User) might have multiple children (StudentProfile) learning Quran.
/// The "Siblings" plan ($100/mo) allows up to 3 kids under 1 login.
/// The User is the account owner who pays; StudentProfiles are the learners.
model User {
  id            String    @id @default(cuid())
  orgId         String
  email         String
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  phone         String?
  role          UserRole  @default(STUDENT)

  /// Better Auth fields — these store session/auth data
  /// 📚 WHY STORE AUTH DATA IN OUR DB? Better Auth uses our database
  /// as the session store (no Redis needed). This means auth state is
  /// always consistent with our business data.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? /// Soft delete

  // Relations
  org              Organization      @relation(fields: [orgId], references: [id])
  studentProfiles  StudentProfile[]  /// A parent can have multiple child profiles
  teacherSessions  Session[]         @relation("TeacherSessions") /// Sessions taught
  bookings         Booking[]
  sentMessages     ChatMessage[]     @relation("SentMessages")
  feedbackGiven    TeacherFeedback[] @relation("FeedbackGiven")
  feedbackReceived TeacherFeedback[] @relation("FeedbackReceived")
  subscriptions    Subscription[]
  observerEmails   ObserverEmail[]
  pushSubscriptions PushSubscription[]
  auditLogs        AuditLog[]
  couponRedemptions CouponRedemption[]

  @@unique([email, orgId]) /// Same email can exist in different orgs
  @@index([orgId])
  @@map("users")
}

/// StudentProfile represents an individual learner (could be the user themselves
/// or a child/dependent). This is where we track Quran learning progress.
/// 📚 WHY A SEPARATE TABLE? Consider a mother with 3 children:
/// - She has 1 User account (she logs in, pays the bills)
/// - She has 3 StudentProfiles (one per child, each with their own progress)
/// - On the Siblings plan, all 3 share her subscription
model StudentProfile {
  id           String  @id @default(cuid())
  userId       String  /// The parent/account owner
  name         String  /// Child's name
  dateOfBirth  DateTime?
  currentLevel String  @default("qaida-basics") /// e.g., "qaida-basics", "quran-juz-1"
  notes        String? /// Teacher can add learning notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user              User              @relation(fields: [userId], references: [id])
  sessionAttendees  SessionAttendee[]
  progressRecords   ProgressRecord[]

  @@index([userId])
  @@map("student_profiles")
}

/// Plan defines a pricing tier. Plans belong to an org so each school
/// can customize pricing (within the standard tier structure).
/// 📚 PRICING RULES (HARDCODED BUSINESS LOGIC):
/// - FREE: $0, webinar only, no chat, muted
/// - INDIVIDUAL: $70/mo, 4 classes/week, 1:1, full chat, teacher feedback
/// - GROUP: $50/mo, 4 classes/week, group of 3, full chat
/// - SIBLINGS: $100/mo, 4 classes/week per child, up to 3 children
model Plan {
  id                String    @id @default(cuid())
  orgId             String
  tier              PlanTier
  name              String    /// Display name (e.g., "1:1 Premium Plan")
  description       String?
  priceInCents      Int       /// Price in cents (e.g., 7000 = $70.00)
  currency          String    @default("usd")
  classesPerWeek    Int       @default(4) /// Entitlement: how many classes per week
  maxStudents       Int       @default(1) /// Siblings plan allows up to 3
  sessionType       SessionType
  stripePriceId     String?   /// Linked Stripe Price object
  stripeProductId   String?   /// Linked Stripe Product object
  isActive          Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org           Organization   @relation(fields: [orgId], references: [id])
  subscriptions Subscription[]

  @@index([orgId])
  @@map("plans")
}

/// Subscription links a User to a Plan with payment tracking via Stripe.
/// 📚 WHY TRACK STRIPE IDs LOCALLY? We need to:
/// 1. Show subscription status without calling Stripe
/// 2. Handle webhook events that update status asynchronously
/// 3. Support the manual invoice flow where payment is delayed
model Subscription {
  id                    String             @id @default(cuid())
  orgId                 String
  userId                String
  planId                String
  stripeSubscriptionId  String?            @unique
  stripeCustomerId      String?
  status                SubscriptionStatus @default(ACTIVE)
  paymentMethod         PaymentMethod      @default(MANUAL_INVOICE)
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org          Organization  @relation(fields: [orgId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  plan         Plan          @relation(fields: [planId], references: [id])
  entitlements Entitlement[]

  @@index([orgId])
  @@index([userId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

/// Entitlement is the "ledger" that tracks how many classes a student
/// is allowed per week. It's the bridge between payment and access.
/// 📚 THE LEDGER PATTERN: Instead of a simple counter that we increment/decrement
/// (which can drift due to bugs or race conditions), we calculate the
/// remaining quota by: totalAllowed - COUNT(bookings this week).
/// This is auditable, debuggable, and self-healing.
model Entitlement {
  id              String   @id @default(cuid())
  subscriptionId  String
  weekStartDate   DateTime /// Monday 00:00 UTC of the entitlement week
  totalClasses    Int      /// e.g., 4 for standard plans
  usedClasses     Int      @default(0) /// Incremented when a booking is created

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, weekStartDate]) /// One entitlement per subscription per week
  @@map("entitlements")
}

/// Booking represents a student's reserved class slot for a specific session.
/// 📚 BOOKING vs SESSION: A Session is the "class" (teacher + time + room).
/// A Booking is the student's reservation in that class. For group sessions,
/// one Session can have multiple Bookings (up to 3 for GROUP, 20 for WEBINAR).
model Booking {
  id        String        @id @default(cuid())
  orgId     String
  userId    String        /// The account owner who booked
  sessionId String
  status    BookingStatus @default(CONFIRMED)

  /// Cal.com integration fields
  calcomBookingId String? /// Links back to the Cal.com booking
  calcomEventId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cancelledAt DateTime?

  // Relations
  org     Organization @relation(fields: [orgId], references: [id])
  user    User         @relation(fields: [userId], references: [id])
  session Session      @relation(fields: [sessionId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@index([sessionId])
  @@map("bookings")
}

/// Session is a live teaching session (class). It's the core unit of the product.
/// 📚 SESSION LIFECYCLE:
/// 1. SCHEDULED: Created when a booking is confirmed
/// 2. IN_PROGRESS: Teacher starts the call → Jitsi room is created
/// 3. COMPLETED: Session ends (after 30 min or teacher extends)
/// 4. CANCELLED: Either party cancels before start time
/// 5. NO_SHOW: Student didn't join within grace period
model Session {
  id            String        @id @default(cuid())
  orgId         String
  teacherId     String
  type          SessionType
  status        SessionStatus @default(SCHEDULED)
  title         String?       /// e.g., "Qaida Lesson 5 — Letters Ba-Ta-Tha"

  /// Scheduling
  scheduledStart DateTime
  scheduledEnd   DateTime     /// Default: scheduledStart + 30 min
  actualStart    DateTime?
  actualEnd      DateTime?
  isExtended     Boolean      @default(false) /// Teacher extended past 30 min
  extensionMin   Int          @default(0)     /// How many extra minutes

  /// Jitsi integration
  jitsiRoomName  String?     @unique /// Derived from session ID for uniqueness
  jitsiJwt       String?     /// Generated JWT for room access (ephemeral)

  /// Recording
  recordingUrl   String?     /// URL to session recording (if teacher enabled it)
  recordingAccessible Boolean @default(false) /// Teacher controls access

  /// Cal.com integration
  calcomEventId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org       Organization      @relation(fields: [orgId], references: [id])
  teacher   User              @relation("TeacherSessions", fields: [teacherId], references: [id])
  bookings  Booking[]
  attendees SessionAttendee[]
  messages  ChatMessage[]
  feedback  TeacherFeedback[]

  @@index([orgId])
  @@index([teacherId])
  @@index([scheduledStart])
  @@map("sessions")
}

/// SessionAttendee tracks which StudentProfile attended which Session.
/// 📚 WHY SEPARATE FROM BOOKING? A Booking is about the account owner's
/// reservation. An Attendee record tracks which specific student profile
/// (child) actually attended. This matters for the Siblings plan where
/// one booking might cover different children on different days.
model SessionAttendee {
  id               String  @id @default(cuid())
  sessionId        String
  studentProfileId String
  joinedAt         DateTime?
  leftAt           DateTime?
  durationMinutes  Int?    /// Calculated: leftAt - joinedAt

  // Relations
  session        Session        @relation(fields: [sessionId], references: [id])
  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@unique([sessionId, studentProfileId])
  @@map("session_attendees")
}

/// ProgressRecord tracks lesson completion. Progress requires teacher approval.
/// 📚 THE APPROVAL PATTERN: Students don't self-report progress. The teacher
/// marks a lesson as complete, optionally with notes. This ensures
/// data integrity — a student can't skip ahead without teacher sign-off.
model ProgressRecord {
  id               String  @id @default(cuid())
  studentProfileId String
  lessonId         String  /// e.g., "qaida-lesson-5" (matches curriculum system)
  lessonTitle      String
  isCompleted      Boolean @default(false)
  completedAt      DateTime?
  teacherApproved  Boolean @default(false)
  teacherNotes     String?
  score            Int?    /// Optional 1-100 score

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@unique([studentProfileId, lessonId])
  @@index([studentProfileId])
  @@map("progress_records")
}

/// ChatMessage supports the moderated in-session chat.
/// 📚 MODERATION PATTERN: Messages are visible by default. Teachers and admins
/// can "hide" a message by setting `isHidden = true`. The message is never
/// deleted (audit trail), but the frontend filters hidden messages for students.
/// This is a common pattern in educational platforms for child safety.
model ChatMessage {
  id        String   @id @default(cuid())
  orgId     String
  sessionId String
  senderId  String
  content   String
  isHidden  Boolean  @default(false) /// Set to true by teacher/admin moderation
  hiddenBy  String?  /// Who hid this message (for audit)
  hiddenAt  DateTime?

  createdAt DateTime @default(now())

  // Relations
  org     Organization @relation(fields: [orgId], references: [id])
  session Session      @relation(fields: [sessionId], references: [id])
  sender  User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([sessionId])
  @@index([orgId])
  @@map("chat_messages")
}

/// TeacherFeedback is audio feedback from teacher to student.
/// 📚 WHY AUDIO? Quran learning relies heavily on pronunciation (Tajweed).
/// Text feedback can't capture "your 'ain' sound needs more depth."
/// Teachers record a short audio clip reviewing the student's recitation.
model TeacherFeedback {
  id               String  @id @default(cuid())
  sessionId        String
  teacherId        String
  studentId        String  /// The student account owner (User)
  audioUrl         String  /// URL to the audio file (stored in S3/R2)
  transcription    String? /// Optional AI transcription for search
  duration         Int?    /// Audio duration in seconds
  notes            String? /// Optional text notes alongside audio

  createdAt DateTime @default(now())

  // Relations
  session Session @relation(fields: [sessionId], references: [id])
  teacher User    @relation("FeedbackGiven", fields: [teacherId], references: [id])
  student User    @relation("FeedbackReceived", fields: [studentId], references: [id])

  @@index([sessionId])
  @@index([studentId])
  @@map("teacher_feedback")
}

/// ObserverEmail allows parents/guardians to add observer email addresses
/// that receive weekly progress digests. By default, all profiles are included.
/// 📚 USE CASE: A father adds his wife's email. Every Sunday, she receives
/// an email summarizing each child's Quran progress for the week.
model ObserverEmail {
  id           String   @id @default(cuid())
  userId       String   /// The account owner who configured this
  email        String   /// The observer's email address
  isActive     Boolean  @default(true)
  profileIds   String[] /// Which student profiles to include (empty = all)
  frequency    String   @default("weekly") /// "weekly" or "daily"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@unique([userId, email])
  @@map("observer_emails")
}

/// Coupon for discounts on plans. Org admins create these.
/// 📚 COUPON vs STRIPE COUPON: We store coupons locally AND in Stripe.
/// Local storage lets us enforce org-scoped limits (e.g., "only for org X"),
/// while Stripe handles the actual discount on the invoice.
model Coupon {
  id               String   @id @default(cuid())
  orgId            String
  code             String   /// e.g., "RAMADAN2025"
  description      String?
  discountPercent  Int?     /// e.g., 20 for 20% off
  discountAmountCents Int?  /// OR flat amount (e.g., 1000 = $10 off)
  maxRedemptions   Int?     /// null = unlimited
  currentRedemptions Int    @default(0)
  validFrom        DateTime @default(now())
  validUntil       DateTime?
  isActive         Boolean  @default(true)
  stripeCouponId   String?  /// Linked Stripe Coupon object
  applicableTiers  PlanTier[] /// Which plan tiers this coupon applies to

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org         Organization       @relation(fields: [orgId], references: [id])
  redemptions CouponRedemption[]

  @@unique([orgId, code]) /// Coupon codes are unique per org
  @@index([orgId])
  @@map("coupons")
}

/// CouponRedemption tracks who used what coupon. Prevents double-use.
model CouponRedemption {
  id       String @id @default(cuid())
  couponId String
  userId   String

  redeemedAt DateTime @default(now())

  // Relations
  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([couponId, userId]) /// Each user can only redeem a coupon once
  @@map("coupon_redemptions")
}

/// PushSubscription stores Web Push VAPID subscription data.
/// 📚 WHY WEB PUSH? When a teacher clicks "Call Now," the student needs
/// to be notified immediately. Web Push works even when the browser tab
/// is closed (on desktop). For mobile, we'd add FCM later.
model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  endpoint String @unique /// The push service endpoint URL
  p256dh   String /// Client's public encryption key
  auth     String /// Client's auth secret

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("push_subscriptions")
}

/// AuditLog records every significant action in the system.
/// 📚 WHY AUDIT LOGS? Compliance + debugging + security. When an admin
/// says "who changed this student's plan?", we can answer with certainty.
/// Audit logs are append-only (never update/delete) and include the actor,
/// action, target, and a JSON blob of contextual metadata.
model AuditLog {
  id       String      @id @default(cuid())
  orgId    String?     /// Null for super-admin actions
  actorId  String?     /// Null for system actions (e.g., webhook handlers)
  action   AuditAction
  target   String?     /// What was acted upon (e.g., "user:cuid123")
  metadata Json        @default("{}") /// Additional context as JSON
  ipAddress String?

  createdAt DateTime @default(now())

  // Relations
  org   Organization? @relation(fields: [orgId], references: [id])
  actor User?         @relation(fields: [actorId], references: [id])

  @@index([orgId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
